datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS
// ==========================================

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  BLOCKED
  DEFERRED
  CANCELLED
}

enum RiskLevel {
  HIGH
  MEDIUM
  LOW
}

enum EvidenceKind {
  LINK
  FILE
}

enum CheckinType {
  IN
  OUT
}

enum WorkStatus {
  WFH
  WFO
  ONSITE
}

enum SystemRole {
  EMPLOYEE
  MANAGER
  PM_ADMIN
  HR
  CTO
  SUPER_ADMIN
}

enum CheckinMode {
  TWICE
  ONCE
}

enum EmploymentStatus {
  AKTIF
  NONAKTIF
}

enum LeaveType {
  CUTI
  IZIN
  SAKIT
  LEMBUR
  WFH_EXTRA
  TUKAR_WFO
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  AUTO_APPROVED
}

enum PolicyScopeType {
  TENANT
  DEPARTMENT
  ROLE
}

enum LocationType {
  OFFICE
  CLIENT
}

enum KPIPeriod {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum RiskProbability {
  HIGH
  MEDIUM
  LOW
}

enum RiskImpact {
  HIGH
  MEDIUM
  LOW
}

enum RiskStatus {
  OPEN
  MITIGATED
  CLOSED
  ACCEPTED
}

enum GateDecisionStatus {
  GO
  NO_GO
  CONDITIONAL
}

enum ScorecardPeriodType {
  SPRINT
  MONTH
}

enum RAGStatus {
  GREEN
  YELLOW
  RED
  BLACK
}

enum NotificationKind {
  MENTION
  APPROVAL_IN
  APPROVAL_DECIDED
  REMINDER_CHECKIN
  REMINDER_CHECKOUT
  TASK_ASSIGNED
  ESCALATION
}

enum BlockerStatus {
  OPEN
  RESOLVED
}

// ==========================================
// MODELS
// ==========================================

// 1. Tenants (Akar multi-tenant)
model Tenant {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String    @unique
  theme_json Json?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  users              User[]
  departments        Department[]
  functional_roles   FunctionalRole[]
  teams              Team[]
  team_members       TeamMember[]
  projects           Project[]
  sprints            Sprint[]
  tasks              Task[]
  task_assignments   TaskAssignment[]
  task_dependencies  TaskDependency[]
  task_evidences     TaskEvidence[]
  checkins           Checkin[]
  standup_items      StandupItem[]
  blockers           Blocker[]
  leave_requests     LeaveRequest[]
  policies           Policy[]
  wfh_quotas         WfhQuota[]
  locations          Location[]
  holidays           Holiday[]
  settings           Setting[]
  kpis               KPI[]
  kpi_actuals        KpiActual[]
  okrs               OKR[]
  key_results        KeyResult[]
  risks              Risk[]
  gates              Gate[]
  gate_decisions     GateDecision[]
  scorecards         Scorecard[]
  review_notes       ReviewNote[]
  notifications      Notification[]
  push_subscriptions PushSubscription[]
  audit_logs         AuditLog[]
}

// 2. Users
model User {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String           @db.Uuid
  email              String           @unique
  password_hash      String
  full_name          String
  nik                String
  department_id      String?          @db.Uuid
  functional_role_id String?          @db.Uuid
  manager_id         String?          @db.Uuid
  system_roles       SystemRole[]     @default([EMPLOYEE])
  timezone           String           @default("Asia/Jakarta")
  checkin_mode       CheckinMode      @default(TWICE)
  leave_balance      Int              @default(12)
  employment_status  EmploymentStatus @default(AKTIF)
  joined_at          DateTime         @db.Timestamptz(6)

  tenant             Tenant          @relation(fields: [tenant_id], references: [id])
  department         Department?     @relation(fields: [department_id], references: [id])
  functional_role    FunctionalRole? @relation(fields: [functional_role_id], references: [id])
  manager            User?           @relation("UserManager", fields: [manager_id], references: [id])
  subordinates       User[]          @relation("UserManager")

  task_assignments      TaskAssignment[]
  task_evidences        TaskEvidence[]
  checkins              Checkin[]
  blockers_reported     Blocker[]          @relation("BlockerReporter")
  blockers_resolved     Blocker[]          @relation("BlockerResolver")
  leave_requests        LeaveRequest[]     @relation("LeaveRequester")
  leave_approvals       LeaveRequest[]     @relation("LeaveApprover")
  wfh_quotas            WfhQuota[]
  scorecards            Scorecard[]
  review_notes_authored ReviewNote[]
  notifications         Notification[]
  push_subscriptions    PushSubscription[]
  audit_logs            AuditLog[]
  team_members          TeamMember[]
  okrs                  OKR[]
  risks                 Risk[]
  gate_decisions        GateDecision[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 3. Departments
model Department {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id String    @db.Uuid
  name      String
  tenant    Tenant    @relation(fields: [tenant_id], references: [id])
  users     User[]
  // Policy.scope_id is polymorphic and no longer FK-linked to Department.

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 4. Functional Roles
model FunctionalRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id String   @db.Uuid
  name      String
  code      String   // PO, SA, Infra, BE, FE, QA, TW, Sales
  tenant    Tenant   @relation(fields: [tenant_id], references: [id])
  users     User[]
  tasks     Task[]
  kpis      KPI[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 5. Teams
model Team {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  project_id String?  @db.Uuid
  name       String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  project    Project? @relation(fields: [project_id], references: [id])

  members TeamMember[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 6. Team Members
model TeamMember {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id String @db.Uuid
  team_id   String @db.Uuid
  user_id   String @db.Uuid
  tenant    Tenant @relation(fields: [tenant_id], references: [id])
  team      Team   @relation(fields: [team_id], references: [id])
  user      User   @relation(fields: [user_id], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@unique([team_id, user_id])
}

// 7. Projects
model Project {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String        @db.Uuid
  name        String
  code_prefix String
  status      ProjectStatus @default(ACTIVE)
  tenant      Tenant        @relation(fields: [tenant_id], references: [id])

  sprints  Sprint[]
  tasks    Task[]
  teams    Team[]
  checkins Checkin[]
  okrs     OKR[]
  risks    Risk[]
  gates    Gate[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 8. Sprints
model Sprint {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  project_id String   @db.Uuid
  number     Int
  start_date DateTime @db.Timestamptz(6)
  end_date   DateTime @db.Timestamptz(6)
  goal       String?
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  project    Project  @relation(fields: [project_id], references: [id])

  tasks Task[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 9. Tasks
model Task {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String       @db.Uuid
  sprint_id          String       @db.Uuid
  project_id         String       @db.Uuid
  functional_role_id String?      @db.Uuid
  code               String       @unique // e.g., PREFIX-SS-NNNN
  workstream         String
  title              String
  deliverable        String?
  priority           TaskPriority @default(MEDIUM)
  planned_start      DateTime     @db.Timestamptz(6)
  planned_end        DateTime     @db.Timestamptz(6)
  status             TaskStatus   @default(NOT_STARTED)
  percent_complete   Int          @default(0)
  weight             Decimal      @default(1.0) @db.Decimal(10, 2)
  risk_level         RiskLevel    @default(LOW)
  rag_override       RAGStatus?
  rag_override_reason String?
  kpi_id             String?      @db.Uuid
  okr_kr_id          String?      @db.Uuid
  notes              String?

  tenant          Tenant          @relation(fields: [tenant_id], references: [id])
  sprint          Sprint          @relation(fields: [sprint_id], references: [id])
  project         Project         @relation(fields: [project_id], references: [id])
  functional_role FunctionalRole? @relation(fields: [functional_role_id], references: [id])
  kpi             KPI?            @relation(fields: [kpi_id], references: [id])
  okr_kr          KeyResult?      @relation(fields: [okr_kr_id], references: [id])

  assignments  TaskAssignment[]
  dependencies TaskDependency[] @relation("TaskDependent")
  dependents   TaskDependency[] @relation("TaskDependsOn")
  evidences    TaskEvidence[]
  standup_items StandupItem[]
  blockers     Blocker[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 10. Task Assignments
model TaskAssignment {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  task_id       String    @db.Uuid
  user_id       String    @db.Uuid
  assigned_at   DateTime  @default(now()) @db.Timestamptz(6)
  unassigned_at DateTime? @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  task   Task   @relation(fields: [task_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 11. Task Dependencies
model TaskDependency {
  id                 String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String @db.Uuid
  task_id            String @db.Uuid
  depends_on_task_id String @db.Uuid

  tenant     Tenant @relation(fields: [tenant_id], references: [id])
  task       Task   @relation("TaskDependent", fields: [task_id], references: [id])
  depends_on Task   @relation("TaskDependsOn", fields: [depends_on_task_id], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@unique([task_id, depends_on_task_id])
}

// 12. Task Evidences
model TaskEvidence {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String       @db.Uuid
  task_id      String       @db.Uuid
  kind         EvidenceKind
  url_or_key   String
  uploaded_by  String       @db.Uuid

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  task   Task   @relation(fields: [task_id], references: [id])
  user   User   @relation(fields: [uploaded_by], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 13. Checkins
model Checkin {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String      @db.Uuid
  user_id           String      @db.Uuid
  date              DateTime    @db.Date
  type              CheckinType
  work_status       WorkStatus
  client_project_id String?     @db.Uuid
  lat               Decimal?    @db.Decimal(10, 8)
  lng               Decimal?    @db.Decimal(11, 8)
  gps_accuracy_m    Decimal?    @db.Decimal(10, 2)
  selfie_key        String?
  is_auto           Boolean     @default(false)
  is_late           Boolean     @default(false)
  is_offline_sync   Boolean     @default(false)
  geofence_ok       Boolean     @default(true)
  device_timestamp  DateTime    @db.Timestamptz(6)
  submitted_at      DateTime    @default(now()) @db.Timestamptz(6)
  daily_note        String?

  tenant         Tenant   @relation(fields: [tenant_id], references: [id])
  user           User     @relation(fields: [user_id], references: [id])
  client_project Project? @relation(fields: [client_project_id], references: [id])

  standup_items StandupItem[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@unique([user_id, date, type])
}

// 14. Standup Items
model StandupItem {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String      @db.Uuid
  checkin_id      String      @db.Uuid
  task_id         String      @db.Uuid
  note            String?
  planned         Boolean     @default(true)
  percent_after   Int?
  status_after    TaskStatus?
  is_carried_over Boolean     @default(false)

  tenant  Tenant  @relation(fields: [tenant_id], references: [id])
  checkin Checkin @relation(fields: [checkin_id], references: [id])
  task    Task    @relation(fields: [task_id], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 15. Blockers
model Blocker {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String        @db.Uuid
  task_id            String        @db.Uuid
  reported_by        String        @db.Uuid
  description        String
  mentioned_user_ids String[]      @db.Uuid
  status             BlockerStatus @default(OPEN)
  opened_at          DateTime      @default(now()) @db.Timestamptz(6)
  resolved_at        DateTime?     @db.Timestamptz(6)
  resolved_by        String?       @db.Uuid

  tenant   Tenant @relation(fields: [tenant_id], references: [id])
  task     Task   @relation(fields: [task_id], references: [id])
  reporter User   @relation("BlockerReporter", fields: [reported_by], references: [id])
  resolver User?  @relation("BlockerResolver", fields: [resolved_by], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 16. Leave Requests
model LeaveRequest {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String      @db.Uuid
  user_id        String      @db.Uuid
  approver_id    String?     @db.Uuid
  type           LeaveType
  date_from      DateTime    @db.Timestamptz(6)
  date_to        DateTime    @db.Timestamptz(6)
  hours          Decimal?    @db.Decimal(5, 2)
  attachment_key String?
  reason         String
  status         LeaveStatus @default(PENDING)
  decided_at     DateTime?   @db.Timestamptz(6)
  decision_note  String?
  escalated_at   DateTime?   @db.Timestamptz(6)

  tenant    Tenant @relation(fields: [tenant_id], references: [id])
  requester User   @relation("LeaveRequester", fields: [user_id], references: [id])
  approver  User?  @relation("LeaveApprover", fields: [approver_id], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 17. Policies (F2)
model Policy {
  id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id               String          @db.Uuid
  scope_type              PolicyScopeType
  scope_id                String          @db.Uuid
  wfh_days_per_week       Int
  mandatory_wfo_weekdays  Int[]
  checkin_window_start    String          // HH:mm
  checkin_window_end      String          // HH:mm
  auto_checkout_at        String          // HH:mm
  default_checkin_mode    CheckinMode     @default(TWICE)

  tenant     Tenant      @relation(fields: [tenant_id], references: [id])
  // scope_id is polymorphic (tenant | department | role id per scope_type), so it
  // must NOT be FK-constrained to Department. The former Policy_scope_id_fkey_dept
  // FK made TENANT/ROLE-scoped rows un-insertable; dropped in migration
  // 20260705120000_drop_policy_scope_id_dept_fk.

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 18. Wfh Quotas (F2)
model WfhQuota {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  user_id    String   @db.Uuid
  week_start DateTime @db.Date
  used_days  Int      @default(0)

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@unique([user_id, week_start])
}

// 19. Locations
model Location {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id String       @db.Uuid
  name      String
  type      LocationType
  lat       Decimal?     @db.Decimal(10, 8)
  lng       Decimal?     @db.Decimal(11, 8)
  radius_m  Int          @default(200)

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 20. Holidays
model Holiday {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @db.Uuid
  date            DateTime @db.Date
  name            String
  is_cuti_bersama Boolean  @default(false)

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@unique([tenant_id, date])
}

// 21. Settings
model Setting {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String @db.Uuid
  key        String
  value_json Json

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@unique([tenant_id, key])
}

// 22. KPIs (F3)
model KPI {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String         @db.Uuid
  functional_role_id String         @db.Uuid
  name               String
  target             Decimal        @db.Decimal(12, 2)
  unit               String
  period             KPIPeriod

  tenant          Tenant         @relation(fields: [tenant_id], references: [id])
  functional_role FunctionalRole @relation(fields: [functional_role_id], references: [id])
  actuals         KpiActual[]
  tasks           Task[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 23. KPI Actuals (F3)
model KpiActual {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String   @db.Uuid
  kpi_id       String   @db.Uuid
  period_start DateTime @db.Date
  actual       Decimal  @db.Decimal(12, 2)

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  kpi    KPI    @relation(fields: [kpi_id], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 24. OKRs (F3)
model OKR {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  project_id String   @db.Uuid
  objective  String
  quarter    String
  owner_id   String   @db.Uuid

  tenant  Tenant  @relation(fields: [tenant_id], references: [id])
  project Project @relation(fields: [project_id], references: [id])
  owner   User    @relation(fields: [owner_id], references: [id])

  key_results KeyResult[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 25. Key Results (F3)
model KeyResult {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  okr_id      String   @db.Uuid
  description String
  target      Decimal  @db.Decimal(12, 2)
  actual      Decimal  @default(0) @db.Decimal(12, 2)
  unit        String

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  okr    OKR    @relation(fields: [okr_id], references: [id])
  tasks  Task[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 26. Risks (F3)
model Risk {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String          @db.Uuid
  project_id  String          @db.Uuid
  description String
  category    String
  probability RiskProbability
  impact      RiskImpact
  mitigation  String
  owner_id    String          @db.Uuid
  status      RiskStatus      @default(OPEN)

  tenant  Tenant  @relation(fields: [tenant_id], references: [id])
  project Project @relation(fields: [project_id], references: [id])
  owner   User    @relation(fields: [owner_id], references: [id])

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

// 27. Gates (F3)
model Gate {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String   @db.Uuid
  project_id    String   @db.Uuid
