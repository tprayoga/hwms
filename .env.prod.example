# ============================================================================
# HWMS production environment template. Copy to `.env.prod`, fill in strong
# secrets, and keep it OUT of version control:
#   cp .env.prod.example .env.prod
# Generate secrets with: openssl rand -base64 48
# ============================================================================

# --- Database ---
POSTGRES_USER=hwms
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=hwms
# Host is the compose service name `postgres`.
DATABASE_URL=postgresql://hwms:CHANGE_ME_strong_db_password@postgres:5432/hwms?schema=public

# --- Object storage (MinIO) ---
S3_ACCESS_KEY=CHANGE_ME_minio_access
S3_SECRET_KEY=CHANGE_ME_minio_secret

# --- JWT secrets (min 32 chars each, distinct) ---
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars

# --- CORS allowlist (comma-separated). In the default nginx-proxied setup the
#     web and API share an origin, so this only matters if the SPA is hosted on
#     a different host than the API. ---
CORS_ORIGINS=https://hwms.saftos.local

# --- Web ---
# Same-origin default; nginx proxies /api to the API service.
VITE_API_URL=/api/v1
WEB_PORT=80

# --- Web Push (VAPID). Generate once with: npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@indotek.com
